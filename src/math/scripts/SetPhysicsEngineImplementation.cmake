# *NOTE*: the first entry is the default option
if (BOX2D_SUPPORT)
 set (PHYSICSENGINE_IMPLEMENTATION "box2d" CACHE STRING "Current Physics Engine Implementation")
 set (SUPPORTED_PHYSICSENGINE_IMPLEMENTATIONS "${SUPPORTED_PHYSICSENGINE_IMPLEMENTATIONS};box2d")
endif (BOX2D_SUPPORT)
if (LIQUIDFUN_SUPPORT)
 set (PHYSICSENGINE_IMPLEMENTATION "liquidfun" CACHE STRING "Current Physics Engine Implementation")
 set (SUPPORTED_PHYSICSENGINE_IMPLEMENTATIONS "${SUPPORTED_PHYSICSENGINE_IMPLEMENTATIONS};liquidfun")
endif (LIQUIDFUN_SUPPORT)
set_property (CACHE PHYSICSENGINE_IMPLEMENTATION PROPERTY STRINGS ${SUPPORTED_PHYSICSENGINE_IMPLEMENTATIONS})

if (NOT DEFINED PHYSICSENGINE_IMPLEMENTATION_LAST)
 set (PHYSICSENGINE_IMPLEMENTATION_LAST "NotAnImplementation" CACHE STRING "last physics engine implementation used")
 mark_as_advanced (FORCE PHYSICSENGINE_IMPLEMENTATION_LAST)
endif (NOT DEFINED PHYSICSENGINE_IMPLEMENTATION_LAST)
if (NOT (${PHYSICSENGINE_IMPLEMENTATION} STREQUAL ${PHYSICSENGINE_IMPLEMENTATION_LAST}))
 unset (CACHE{BOX2D_USE})
 unset (CACHE{LIQUIDFUN_USE})
 set (PHYSICSENGINE_IMPLEMENTATION_LAST ${PHYSICSENGINE_IMPLEMENTATION} CACHE STRING "Updating Physics Engine Implementation Option" FORCE)
endif (NOT (${PHYSICSENGINE_IMPLEMENTATION} STREQUAL ${PHYSICSENGINE_IMPLEMENTATION_LAST}))

if (${PHYSICSENGINE_IMPLEMENTATION} STREQUAL "box2d")
 if (NOT BOX2D_SUPPORT)
  message (FATAL_ERROR "box2d not supported")
 endif (NOT BOX2D_SUPPORT)
 set (BOX2D_USE ON CACHE STRING "use box2d")
 mark_as_advanced (FORCE BOX2D_USE)
 add_definitions (-DBOX2D_USE)
elseif (${PHYSICSENGINE_IMPLEMENTATION} STREQUAL "liquidfun")
 if (NOT LIQUIDFUN_SUPPORT)
  message (FATAL_ERROR "liquidfun not supported")
 endif (NOT LIQUIDFUN_SUPPORT)
 set (LIQUIDFUN_USE ON CACHE STRING "use liquidfun")
 mark_as_advanced (FORCE LIQUIDFUN_USE)
 add_definitions (-DLIQUIDFUN_USE)
endif ()
